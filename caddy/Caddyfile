# Caddyfile — Nervus 反向代理
# 局域网 HTTPS，自动证书（mkcert 或自签）
# 访问：https://nervus.local（需在路由器/hosts 配置 DNS）

{
    # 局域网内使用自签证书
    local_certs
    log {
        level INFO
    }
}

# ── 主域名入口 ──────────────────────────────────
nervus.local {
    # Arbor Core API
    handle /api/* {
        reverse_proxy nervus-arbor:8090
    }

    # WebSocket（实时状态推送）
    handle /ws/* {
        reverse_proxy nervus-arbor:8090 {
            header_up Upgrade {http.upgrade}
            header_up Connection "Upgrade"
        }
    }

    # 默认路由到移动端 Shell 静态文件
    handle {
        root * /srv/mobile
        try_files {path} /index.html
        file_server
    }
}

# ── 各 App 子域名 ──────────────────────────────
calorie.nervus.local {
    reverse_proxy nervus-app-calorie:8001
}


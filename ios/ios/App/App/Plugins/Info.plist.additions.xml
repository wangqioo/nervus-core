<?xml version="1.0" encoding="UTF-8"?>
<!--
  将以下 key 合并到 ios/App/App/Info.plist
  在 Xcode 的 Info 标签页中手动添加，或直接编辑 Info.plist 文件

  同时在 Xcode → Signing & Capabilities 开启：
    - Background Modes:
        [x] Background fetch
        [x] Background processing
        [x] Audio, AirPlay, and Picture in Picture
        [x] Remote notifications
-->
<plist version="1.0">
<dict>

  <!-- 相册访问权限说明 -->
  <key>NSPhotoLibraryUsageDescription</key>
  <string>Nervus 需要访问您的相册，以便自动分析食物照片记录热量，并将旅行照片归入记忆库。</string>

  <key>NSPhotoLibraryAddUsageDescription</key>
  <string>Nervus 需要保存处理后的照片。</string>

  <!-- 麦克风访问权限说明 -->
  <key>NSMicrophoneUsageDescription</key>
  <string>Nervus 需要麦克风权限来录制会议音频，并自动生成会议纪要。</string>

  <!-- 本地网络访问权限说明 -->
  <key>NSLocalNetworkUsageDescription</key>
  <string>Nervus 需要访问局域网，以连接同一网络中的 Nervus 边缘设备。</string>

  <!-- Bonjour 服务类型声明 -->
  <key>NSBonjourServices</key>
  <array>
    <string>_nervus._tcp</string>
    <string>_http._tcp</string>
  </array>

  <!-- 后台任务标识符 -->
  <key>BGTaskSchedulerPermittedIdentifiers</key>
  <array>
    <string>ai.nervus.background-sync</string>
  </array>

  <!-- 允许本地 HTTPS（nervus.local 自签证书） -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsLocalNetworking</key>
    <true/>
    <key>NSExceptionDomains</key>
    <dict>
      <key>nervus.local</key>
      <dict>
        <key>NSExceptionAllowsInsecureHTTPLoads</key>
        <true/>
        <key>NSIncludesSubdomains</key>
        <true/>
      </dict>
    </dict>
  </dict>

</dict>
</plist>

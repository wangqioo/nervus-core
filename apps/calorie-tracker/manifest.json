{
  "id": "calorie-tracker",
  "name": "热量管理",
  "version": "1.0.0",
  "description": "AI 自动记录饮食，跟踪热量目标。拍照即记录，零手动输入。",
  "subscribes": [
    {
      "subject": "media.photo.classified",
      "filter": { "tags_contains": ["food"] },
      "handler": "/intake/photo_classified"
    }
  ],
  "publishes": [
    "health.calorie.meal_logged",
    "health.calorie.budget_alert"
  ],
  "actions": [
    {
      "name": "analyze_meal",
      "description": "分析食物照片，返回食物名称和估算热量",
      "input": { "photo_path": "string", "tags": "array" },
      "output": { "food_name": "string", "calories": "number", "nutrition": "object" }
    },
    {
      "name": "get_today_summary",
      "description": "获取今日热量汇总",
      "input": {},
      "output": { "total_calories": "number", "budget": "number", "remaining": "number", "meals": "array" }
    },
    {
      "name": "set_daily_budget",
      "description": "设置每日热量目标",
      "input": { "calories": "number" },
      "output": { "success": "boolean" }
    }
  ],
  "context_reads": [
    "physical.daily_calorie_budget",
    "physical.calorie_remaining"
  ],
  "context_writes": [
    "physical.last_meal",
    "physical.calorie_remaining"
  ],
  "memory_writes": [
    "health.meal_history"
  ]
}

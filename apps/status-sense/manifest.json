{
  "schema_version": "0.1",
  "id": "status-sense",
  "name": "状态感知仪",
  "type": "nervus",
  "version": "0.1.0",
  "description": "多信号融合的认知负荷推断，计算 low/medium/high 三级状态",
  "icon": "🧠",
  "route": "/api/status-sense",
  "service": {
    "container": "nervus-app-status-sense",
    "internal_url": "http://nervus-app-status-sense:8013",
    "port": 8013
  },
  "capabilities": {
    "actions": [
      {
        "name": "compute_load",
        "description": "立即重新计算认知负荷"
      },
      {
        "name": "get_history",
        "description": "获取认知负荷历史曲线"
      }
    ],
    "consumes": [
      "health.calorie.meal_logged",
      "meeting.recording.processed",
      "media.photo.classified",
      "context.user_state.updated"
    ],
    "emits": [
      "context.user_state.updated"
    ],
    "models": [],
    "writes": []
  }
}
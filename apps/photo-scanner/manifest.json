{
  "schema_version": "0.1",
  "id": "photo-scanner",
  "name": "相册扫描",
  "type": "nervus",
  "version": "0.1.0",
  "description": "定时扫描新照片，AI 分类并发布到 Synapse Bus",
  "icon": "📸",
  "route": "/photo/",
  "service": {
    "container": "nervus-app-photo",
    "internal_url": "http://nervus-app-photo:8006",
    "port": 8006
  },
  "capabilities": {
    "actions": [
      {"name": "classify_photo", "description": "对单张照片进行 AI 分类"},
      {"name": "scan_batch", "description": "批量扫描指定目录下的新照片"}
    ],
    "consumes": [],
    "emits": [
      "media.photo.classified",
      "media.photo.batch_processed",
      "meeting.whiteboard.detected"
    ],
    "models": [],
    "writes": []
  }
}

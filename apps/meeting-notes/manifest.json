{
  "id": "meeting-notes",
  "name": "会议纪要",
  "version": "1.0.0",
  "description": "录音自动转写，白板照片自动整合，生成结构化会议报告",
  "subscribes": [
    {
      "subject": "meeting.whiteboard.detected",
      "filter": {},
      "handler": "/intake/whiteboard_detected"
    }
  ],
  "publishes": [
    "meeting.recording.processed"
  ],
  "actions": [
    {
      "name": "transcribe_and_summarize",
      "description": "转写录音并生成结构化纪要",
      "input": { "audio_path": "string", "meeting_id": "string" },
      "output": { "meeting_id": "string", "transcript": "string", "summary": "object" }
    },
    {
      "name": "integrate_whiteboard",
      "description": "将白板照片内容整合进指定会议纪要",
      "input": { "meeting_id": "string", "photo_path": "string" },
      "output": { "success": "boolean", "ocr_text": "string" }
    },
    {
      "name": "get_meeting",
      "description": "获取指定会议的完整报告",
      "input": { "meeting_id": "string" },
      "output": { "meeting": "object" }
    }
  ],
  "context_reads": [],
  "context_writes": [
    "social.recent_meeting"
  ],
  "memory_writes": [
    "meeting.history"
  ]
}

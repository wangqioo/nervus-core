{
  "schema_version": "0.1",
  "id": "calendar",
  "name": "日程管理",
  "type": "nervus",
  "version": "0.1.0",
  "description": "日程管理与感知时间轴，根据认知负荷调整建议",
  "icon": "📅",
  "route": "/api/calendar",
  "service": {
    "container": "nervus-app-calendar",
    "internal_url": "http://nervus-app-calendar:8011",
    "port": 8011
  },
  "capabilities": {
    "actions": [
      {
        "name": "create_event",
        "description": "创建日程事件"
      },
      {
        "name": "get_today_schedule",
        "description": "获取今日日程"
      },
      {
        "name": "suggest_schedule",
        "description": "根据认知负荷建议日程调整"
      }
    ],
    "consumes": [
      "context.user_state.updated",
      "schedule.event.created",
      "schedule.event.updated",
      "schedule.event.reminder"
    ],
    "emits": [
      "schedule.event.created",
      "schedule.event.updated",
      "schedule.event.reminder"
    ],
    "models": [],
    "writes": []
  }
}
{
  "schema_version": "0.1",
  "id": "reminder",
  "name": "提醒助手",
  "type": "nervus",
  "version": "0.1.0",
  "description": "定时提醒和智能通知，感知最佳触发时机",
  "icon": "⏰",
  "route": "/reminder/",
  "service": {
    "container": "nervus-app-reminder",
    "internal_url": "http://nervus-app-reminder:8012",
    "port": 8012
  },
  "capabilities": {
    "actions": [
      {"name": "create_reminder", "description": "创建提醒"},
      {"name": "snooze_reminder", "description": "暂缓提醒"},
      {"name": "list_upcoming", "description": "获取即将触发的提醒"}
    ],
    "consumes": ["schedule.reminder.triggered", "context.user_state.updated"],
    "emits": ["schedule.reminder.triggered"],
    "models": [],
    "writes": []
  }
}
